<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sigma.ai.evaluation.infrastructure.pg.mapper.IndexTaskMapper">

    <resultMap id="IndexTaskPOMap" type="com.sigma.ai.evaluation.infrastructure.pg.po.IndexTaskPO">
        <id     column="id"             property="id"/>
        <result column="repo_id"        property="repoId"/>
        <result column="task_type"      property="taskType"/>
        <result column="trigger_commit" property="triggerCommit"/>
        <result column="status"         property="status"/>
        <result column="start_time"     property="startTime"/>
        <result column="finish_time"    property="finishTime"/>
        <result column="error_msg"      property="errorMsg"/>
        <result column="create_time"    property="createTime"/>
        <result column="update_time"    property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.sigma.ai.evaluation.infrastructure.pg.po.IndexTaskPO"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_index_task (repo_id, task_type, trigger_commit, status, start_time, create_time, update_time)
        VALUES (#{repoId}, #{taskType}, #{triggerCommit}, #{status}, #{startTime}, NOW(), NOW())
    </insert>

    <update id="updateStatus">
        UPDATE t_index_task
        SET status      = #{status},
            finish_time = NOW(),
            update_time = NOW(),
            error_msg   = #{errorMsg}
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="IndexTaskPOMap" parameterType="long">
        SELECT id, repo_id, task_type, trigger_commit, status, start_time, finish_time, error_msg, create_time, update_time
        FROM t_index_task
        WHERE id = #{id}
    </select>

</mapper>
