<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sigma.ai.evaluation.infrastructure.pg.mapper.RepositoryMapper">

    <resultMap id="RepositoryPOMap" type="com.sigma.ai.evaluation.infrastructure.pg.po.RepositoryPO">
        <id     column="id"          property="id"/>
        <result column="name"        property="name"/>
        <result column="clone_url"   property="cloneUrl"/>
        <result column="branch"      property="branch"/>
        <result column="local_path"  property="localPath"/>
        <result column="status"      property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectAllActive" resultMap="RepositoryPOMap">
        SELECT id, name, clone_url, branch, local_path, status, create_time, update_time
        FROM t_repository
        WHERE status = 1
        ORDER BY create_time
    </select>

    <select id="selectById" resultMap="RepositoryPOMap" parameterType="string">
        SELECT id, name, clone_url, branch, local_path, status, create_time, update_time
        FROM t_repository
        WHERE id = #{id}
    </select>

</mapper>
